---
import Base from "@/layouts/Base.astro";
import AnimatedButton from "@/components/AnimatedButton.astro";
import MainContainer from "@/components/MainContainer.astro";
import CTAShape from "@/components/shape/CTAShape";
---

<Base title="Page Not Found">
  <section class="relative">
    <MainContainer>
      <div class="container-padding-x container-padding-y relative z-2">
        <section class="relative flex w-full items-center justify-center overflow-hidden">
          <!-- Error Card -->
          <div class="relative w-full max-w-297.5 overflow-hidden rounded-[30px] border border-white/6 bg-card/70">
            <!-- Top glow -->
            <div class="pointer-events-none absolute left-1/2 -top-48.5 size-86 -translate-x-1/2">
              <div class="absolute inset-[-29.07%]">
                <svg class="block size-full" fill="none" preserveAspectRatio="none" viewBox="0 0 544 544">
                  <g filter="url(#filter-top-glow)">
                    <circle cx="272" cy="272" fill="url(#paint-top-glow)" fill-opacity="0.12" r="172" />
                  </g>
                  <defs>
                    <filter color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse" height="544" id="filter-top-glow" width="544" x="0" y="0">
                      <feFlood flood-opacity="0" result="BackgroundImageFix" />
                      <feBlend in="SourceGraphic" in2="BackgroundImageFix" mode="normal" result="shape" />
                      <feGaussianBlur result="effect1_foregroundBlur" stdDeviation="50" />
                    </filter>
                    <linearGradient gradientUnits="userSpaceOnUse" id="paint-top-glow" x1="100" x2="444" y1="444" y2="444">
                      <stop stop-color="#8F2FFE" />
                      <stop offset="1" stop-color="#DF53FE" />
                    </linearGradient>
                  </defs>
                </svg>
              </div>
            </div>

            <!-- Inner panel -->
            <div class="relative m-5 overflow-hidden rounded-3xl bg-[#1a1c1c]/10">
              <!-- Bottom-left glow -->
              <div class="pointer-events-none absolute -bottom-31 -left-15 size-75.5">
                <div class="absolute inset-[-39.74%]">
                  <svg class="block size-full" fill="none" preserveAspectRatio="none" viewBox="0 0 542 542">
                    <g filter="url(#filter-bl)">
                      <circle cx="271" cy="271" fill="url(#glow-bl)" fill-opacity="0.7" r="151" />
                    </g>
                    <defs>
                      <filter color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse" height="542" id="filter-bl" width="542" x="0" y="0">
                        <feFlood flood-opacity="0" result="BackgroundImageFix" />
                        <feBlend in="SourceGraphic" in2="BackgroundImageFix" mode="normal" result="shape" />
                        <feGaussianBlur result="effect1_foregroundBlur" stdDeviation="60" />
                      </filter>
                      <linearGradient gradientUnits="userSpaceOnUse" id="glow-bl" x1="120" x2="422" y1="422" y2="422">
                        <stop stop-color="#8F2FFE" />
                        <stop offset="1" stop-color="#DF53FE" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>

              <!-- Top-right glow -->
              <div class="pointer-events-none absolute -right-15 -top-31 size-75.5">
                <div class="absolute inset-[-39.74%]">
                  <svg class="block size-full" fill="none" preserveAspectRatio="none" viewBox="0 0 542 542">
                    <g filter="url(#filter-tr)">
                      <circle cx="271" cy="271" fill="url(#glow-tr)" fill-opacity="0.7" r="151" />
                    </g>
                    <defs>
                      <filter color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse" height="542" id="filter-tr" width="542" x="0" y="0">
                        <feFlood flood-opacity="0" result="BackgroundImageFix" />
                        <feBlend in="SourceGraphic" in2="BackgroundImageFix" mode="normal" result="shape" />
                        <feGaussianBlur result="effect1_foregroundBlur" stdDeviation="60" />
                      </filter>
                      <linearGradient gradientUnits="userSpaceOnUse" id="glow-tr" x1="120" x2="422" y1="422" y2="422">
                        <stop stop-color="#8F2FFE" />
                        <stop offset="1" stop-color="#DF53FE" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>

              <!-- Inner rounded bg -->
              <div class="relative m-5 flex items-center justify-center rounded-[18px] border border-white/6 bg-card/70 py-16 md:py-24">
                <div class="flex flex-col items-center gap-8 px-4 text-center">
                  <p class="text-[32px] font-semibold leading-10 text-white/90">Ooops...</p>
                  <div class="flex items-end gap-2.5">
                    <p class="text-2xl font-semibold leading-8 text-white">Error</p>
                    <h1 class="bg-linear-to-b from-secondary to-primary bg-clip-text text-[clamp(80px,15vw,220px)] text-transparent">404</h1>
                  </div>
                  <p class="text-[32px] font-semibold leading-10 text-white">Page Not Found!</p>
                  <AnimatedButton href="/" classNames="btn bg-gradient-dark">
                    Go Home
                  </AnimatedButton>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom hero blob -->
          <div class="pointer-events-none absolute -bottom-92.75 left-1/2 z-0 h-129 w-[min(920px,100%)] -translate-x-1/2">
            <div class="absolute inset-[-23.26%_-13.04%]">
              <svg class="block size-full" fill="none" preserveAspectRatio="none" viewBox="0 0 1160 756">
                <g filter="url(#filter-hero-blob)">
                  <path
                    d="M1040 636C1040 568.238 1028.1 501.139 1004.98 438.535C981.867 375.931 947.984 319.048 905.269 271.133C862.554 223.218 811.844 185.21 756.034 159.278C700.225 133.347 640.408 120 580 120C519.592 120 459.775 133.347 403.966 159.278C348.156 185.21 297.446 223.218 254.731 271.133C212.016 319.048 178.133 375.931 155.015 438.535C131.898 501.139 120 568.238 120 636L1040 636Z"
                    fill="url(#paint-hero-blob)"
                    fill-opacity="0.3"
                  />
                </g>
                <defs>
                  <filter color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse" height="756" id="filter-hero-blob" width="1160" x="0" y="0">
                    <feFlood flood-opacity="0" result="BackgroundImageFix" />
                    <feBlend in="SourceGraphic" in2="BackgroundImageFix" mode="normal" result="shape" />
                    <feGaussianBlur result="effect1_foregroundBlur" stdDeviation="60" />
                  </filter>
                  <linearGradient gradientUnits="userSpaceOnUse" id="paint-hero-blob" x1="120" x2="1040" y1="636" y2="636">
                    <stop stop-color="#8F2FFE" />
                    <stop offset="1" stop-color="#DF53FE" />
                  </linearGradient>
                </defs>
              </svg>
            </div>
          </div>
        </section>
      </div>
    </MainContainer>
    <div class="absolute -z-10 bottom-0 left-1/2 -translate-x-1/2">
      <CTAShape />
    </div>
  </section>
</Base>
