---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer.astro";
import config from "@/config/config.json";
import { getSinglePage } from "@/lib/contentParser.astro";
import { render } from "astro:content";

const { apply_form_action } = config.params;

export async function getStaticPaths() {
  const careers = await getSinglePage("careers");
  return careers.map((career: any) => ({
    params: { single: career.id },
    props: { career },
  }));
}

const { career } = Astro.props;

if (career.data.draft) return Astro.redirect("/404");

const { Content } = await render(career);
const { title, meta_title, description, job_info } = career.data;

const jobInfoCards = [
  { icon: "briefcase", label: "Job Type", value: job_info.employ_type },
  { icon: "stack", label: "Experience", value: job_info.experience },
  { icon: "wallet", label: "Salary Range", value: job_info.salary_range },
  { icon: "location", label: "Location", value: job_info.location },
];
---

<Base title={title} meta_title={meta_title} description={description}>
  <section>
    <MainContainer>
      <div class="container-padding-x pt-30 pb-12">
        <div class="flex flex-col gap-10 items-center">
          <h1 class="font-primary font-semibold text-display-l md:text-[60px] text-center text-text capitalize">
            {title}
          </h1>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2.5 w-full max-w-7xl">
            {jobInfoCards.map((card, index) => (
              <div class="bg-card/30 backdrop-blur-xl border border-border/6 rounded-3xl p-8 flex flex-col gap-7 items-center text-center">
                <div class="size-14 rounded-2xl bg-card/70 border border-border/10 flex items-center justify-center relative overflow-hidden">
                  <svg class="size-6 text-text relative z-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    {card.icon === "briefcase" && (
                      <path d="M20 7h-4V5c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM10 5h4v2h-4V5z" />
                    )}
                    {card.icon === "stack" && <path d="M4 7h16M4 12h16M4 17h16" />}
                    {card.icon === "wallet" && (
                      <path d="M21 5H3c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 12H3V7h18v10zm-3-4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" />
                    )}
                    {card.icon === "location" && (
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                    )}
                  </svg>
                  <svg
                    class="absolute bottom-0 left-1/2 -translate-x-1/2 pointer-events-none"
                    width="56"
                    height="38"
                    viewBox="0 0 56 38"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <g filter={`url(#filter0_f_${index})`}>
                      <circle
                        cx="28"
                        cy="40"
                        r="20"
                        fill={`url(#paint0_linear_${index})`}
                        fill-opacity="0.3"
                      />
                    </g>
                    <defs>
                      <filter
                        id={`filter0_f_${index}`}
                        x="-12"
                        y="0"
                        width="80"
                        height="80"
                        filterUnits="userSpaceOnUse"
                        color-interpolation-filters="sRGB"
                      >
                        <feFlood
                          flood-opacity="0"
                          result="BackgroundImageFix"
                        />
                        <feBlend
                          mode="normal"
                          in="SourceGraphic"
                          in2="BackgroundImageFix"
                          result="shape"
                        />
                        <feGaussianBlur
                          stdDeviation="10"
                          result="effect1_foregroundBlur"
                        />
                      </filter>
                      <linearGradient
                        id={`paint0_linear_${index}`}
                        x1="8"
                        y1="60"
                        x2="48"
                        y2="60"
                        gradientUnits="userSpaceOnUse"
                      >
                        <stop stop-color="#9A4DFE" />
                        <stop offset="1" stop-color="#E87CFF" />
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
                <div class="flex flex-col gap-3">
                  <p class="text-gray">{card.label}</p>
                  <p class="font-bold text-h5 text-text">{card.value}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </MainContainer>
  </section>

  <section>
    <MainContainer>
      <div class="container-padding-x py-10">
        <div class="flex flex-col lg:flex-row gap-12 items-start">
          <div class="lg:w-85 shrink-0 order-last lg:order-first w-full">
            <div class="bg-card/30 border border-border/10 rounded-3xl p-8 sticky top-24">
              <form action={apply_form_action} method="post" enctype="multipart/form-data" class="flex flex-col gap-10">
                <div class="flex flex-col gap-5">
                  <p class="font-medium text-h6 text-text">Apply for the position</p>
                  <div class="flex flex-col gap-5">
                    <input type="text" name="name" placeholder="Name" required class="w-full bg-card/30 backdrop-blur-sm border border-border/6 rounded-full px-7 py-3 text-gray placeholder:text-gray focus:outline-none focus:border-primary/50" />
                    <input type="email" name="email" placeholder="Email" required class="w-full bg-card/30 backdrop-blur-sm border border-border/6 rounded-full px-7 py-3 text-gray placeholder:text-gray focus:outline-none focus:border-primary/50" />
                    <input type="tel" name="phone" placeholder="Phone" class="w-full bg-card/30 backdrop-blur-sm border border-border/6 rounded-full px-7 py-3 text-gray placeholder:text-gray focus:outline-none focus:border-primary/50" />
                    <label for="cv-upload" class="w-full bg-card/30 backdrop-blur-sm border border-dashed border-border/6 rounded-full px-7 py-3 text-gray hover:border-primary/50 transition-colors duration-200 flex items-center gap-2.5 cursor-pointer">
                      <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" />
                      </svg>
                      Upload your cv
                    </label>
                    <input id="cv-upload" type="file" name="cv" accept=".pdf,.doc,.docx" required class="hidden" />
                    <textarea name="message" placeholder="Why are you applying?" rows="4" required class="w-full bg-card/30 backdrop-blur-sm border border-border/6 rounded-2xl px-7 py-3 text-gray placeholder:text-gray focus:outline-none focus:border-primary/50 resize-none" />
                    <input type="hidden" name="position" value={title} />
                  </div>
                </div>
                <button type="submit" class="w-full btn btn-primary">Apply Now</button>
              </form>
            </div>
          </div>
          <div class="flex-1 min-w-0 border-l border-border/6 lg:pl-12">
            <div class="content prose prose-invert max-w-none">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </MainContainer>
  </section>
</Base>
