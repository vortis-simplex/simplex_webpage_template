---
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.astro";
import KeyFeatures from "@/partials/KeyFeatures.astro"; // Map to "Features"
import WhyChooseUs from "@/partials/WhyChooseUs.astro";  // Map to "About / Product"
import CallToAction from "@/partials/CallToAction.astro"; // Map to "Contact"
import { getListPage } from "@/lib/contentParser";

const homepage = await getListPage("homepage/-index.md");
const features = await getListPage("sections/key-features.md"); 
const engineCapabilities = await getListPage("sections/engine-capabilities.md");
const aboutProduct = await getListPage("sections/why-choose-us.md"); 
const contact = await getListPage("sections/call-to-action.md"); 

const { banner } = homepage.frontmatter;
---

<Base>
  <!-- Hero Section: The Hook -->
  <div id="home">
    <Hero data={banner} />
  </div>

  <!-- Features Section: The Problem & The Shift to Physical AI -->
  <div id="features">
    <KeyFeatures data={features} />
  </div>

  <!-- Features Section: Engine Capabilities -->
  <div id="features">
    <KeyFeatures data={engineCapabilities} />
  </div>

  <!-- About Section: Why Choose Us -->
  <div id="about">
    <WhyChooseUs data={aboutProduct} />
  </div>

  <!-- Contact Section: Single CTA to Email / Register Pilot -->
  <div id="contact">
    <CallToAction data={contact} />
  </div>
</Base>
