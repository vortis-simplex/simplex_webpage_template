---
import Base from "@/layouts/Base.astro";
import MainContainer from "@/components/MainContainer.astro";
import CTAShape from "@/components/shape/CTAShape";
---

<Base title="Sign In">
  <section class="relative">
    <MainContainer>
      <div class="container-padding-x container-padding-y relative z-2">
        <section
          class="relative flex w-full items-center justify-center overflow-hidden"
        >
          <!-- Error Card -->
          <div
            class="relative w-full max-w-165 overflow-hidden rounded-[30px] border border-white/6 bg-card/70"
          >
            <!-- Top glow -->
            <div
              class="pointer-events-none absolute left-1/2 -top-48.5 size-86 -translate-x-1/2"
            >
              <div class="absolute inset-[-29.07%]">
                <svg
                  class="block size-full"
                  fill="none"
                  preserveAspectRatio="none"
                  viewBox="0 0 544 544"
                >
                  <g filter="url(#filter-top-glow)">
                    <circle
                      cx="272"
                      cy="272"
                      fill="url(#paint-top-glow)"
                      fill-opacity="0.12"
                      r="172"></circle>
                  </g>
                  <defs>
                    <filter
                      color-interpolation-filters="sRGB"
                      filterUnits="userSpaceOnUse"
                      height="544"
                      id="filter-top-glow"
                      width="544"
                      x="0"
                      y="0"
                    >
                      <feFlood flood-opacity="0" result="BackgroundImageFix"
                      ></feFlood>
                      <feBlend
                        in="SourceGraphic"
                        in2="BackgroundImageFix"
                        mode="normal"
                        result="shape"></feBlend>
                      <feGaussianBlur
                        result="effect1_foregroundBlur"
                        stdDeviation="50"></feGaussianBlur>
                    </filter>
                    <linearGradient
                      gradientUnits="userSpaceOnUse"
                      id="paint-top-glow"
                      x1="100"
                      x2="444"
                      y1="444"
                      y2="444"
                    >
                      <stop stop-color="#8F2FFE"></stop>
                      <stop offset="1" stop-color="#DF53FE"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
            </div>

            <!-- Inner panel -->
            <div
              class="relative m-5 overflow-hidden rounded-3xl bg-[#1a1c1c]/10"
            >
              <!-- Bottom-left glow -->
              <div
                class="pointer-events-none absolute -bottom-31 -left-15 size-75.5"
              >
                <div class="absolute inset-[-39.74%]">
                  <svg
                    class="block size-full"
                    fill="none"
                    preserveAspectRatio="none"
                    viewBox="0 0 542 542"
                  >
                    <g filter="url(#filter-bl)">
                      <circle
                        cx="271"
                        cy="271"
                        fill="url(#glow-bl)"
                        fill-opacity="0.7"
                        r="151"></circle>
                    </g>
                    <defs>
                      <filter
                        color-interpolation-filters="sRGB"
                        filterUnits="userSpaceOnUse"
                        height="542"
                        id="filter-bl"
                        width="542"
                        x="0"
                        y="0"
                      >
                        <feFlood flood-opacity="0" result="BackgroundImageFix"
                        ></feFlood>
                        <feBlend
                          in="SourceGraphic"
                          in2="BackgroundImageFix"
                          mode="normal"
                          result="shape"></feBlend>
                        <feGaussianBlur
                          result="effect1_foregroundBlur"
                          stdDeviation="60"></feGaussianBlur>
                      </filter>
                      <linearGradient
                        gradientUnits="userSpaceOnUse"
                        id="glow-bl"
                        x1="120"
                        x2="422"
                        y1="422"
                        y2="422"
                      >
                        <stop stop-color="#8F2FFE"></stop>
                        <stop offset="1" stop-color="#DF53FE"></stop>
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>

              <!-- Top-right glow -->
              <div
                class="pointer-events-none absolute -right-15 -top-31 size-75.5"
              >
                <div class="absolute inset-[-39.74%]">
                  <svg
                    class="block size-full"
                    fill="none"
                    preserveAspectRatio="none"
                    viewBox="0 0 542 542"
                  >
                    <g filter="url(#filter-tr)">
                      <circle
                        cx="271"
                        cy="271"
                        fill="url(#glow-tr)"
                        fill-opacity="0.7"
                        r="151"></circle>
                    </g>
                    <defs>
                      <filter
                        color-interpolation-filters="sRGB"
                        filterUnits="userSpaceOnUse"
                        height="542"
                        id="filter-tr"
                        width="542"
                        x="0"
                        y="0"
                      >
                        <feFlood flood-opacity="0" result="BackgroundImageFix"
                        ></feFlood>
                        <feBlend
                          in="SourceGraphic"
                          in2="BackgroundImageFix"
                          mode="normal"
                          result="shape"></feBlend>
                        <feGaussianBlur
                          result="effect1_foregroundBlur"
                          stdDeviation="60"></feGaussianBlur>
                      </filter>
                      <linearGradient
                        gradientUnits="userSpaceOnUse"
                        id="glow-tr"
                        x1="120"
                        x2="422"
                        y1="422"
                        y2="422"
                      >
                        <stop stop-color="#8F2FFE"></stop>
                        <stop offset="1" stop-color="#DF53FE"></stop>
                      </linearGradient>
                    </defs>
                  </svg>
                </div>
              </div>

              <!-- Inner rounded bg -->
              <div
                class="relative m-5 flex items-center justify-center rounded-2xl border border-white/6 bg-card/70 p-7.5 py-10"
              >
                <div class="text-center">
                  <h2 class="text-h3">Get Started</h2>
                  <p class="text-text/50">Sign up using Google or Apple.</p>
                  <div class="grid md:grid-cols-2 gap-5 my-10">
                    <button
                      class="btn btn-outline-primary bg-text/5 hover:bg-text/10 flex items-center gap-2 min-w-min w-full justify-center text-sm md:text-base"
                    >
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 20 20"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <g clip-path="url(#clip0_35_9997)">
                          <path
                            d="M6.96721 0.658267C4.9689 1.3515 3.24556 2.66728 2.05032 4.41233C0.855082 6.15739 0.250946 8.23974 0.326651 10.3535C0.402355 12.4673 1.15391 14.5011 2.47092 16.1562C3.78794 17.8113 5.60099 19.0004 7.64377 19.5489C9.2999 19.9762 11.035 19.995 12.7 19.6036C14.2083 19.2648 15.6028 18.5401 16.7469 17.5005C17.9376 16.3854 18.802 14.9668 19.2469 13.3973C19.7305 11.6906 19.8166 9.89566 19.4985 8.15045H10.1985V12.0083H15.5844C15.4768 12.6236 15.2461 13.2108 14.9062 13.7349C14.5663 14.2589 14.1242 14.7091 13.6063 15.0583C12.9486 15.4933 12.2072 15.786 11.4297 15.9176C10.6499 16.0626 9.85011 16.0626 9.07033 15.9176C8.28 15.7542 7.53236 15.428 6.87502 14.9598C5.819 14.2123 5.02608 13.1503 4.6094 11.9255C4.18567 10.6776 4.18567 9.32484 4.6094 8.07702C4.906 7.20235 5.39632 6.40598 6.04377 5.74733C6.7847 4.97975 7.72273 4.43108 8.75495 4.16151C9.78718 3.89195 10.8737 3.91191 11.8953 4.2192C12.6934 4.46419 13.4232 4.89223 14.0266 5.4692C14.6339 4.86504 15.2401 4.25931 15.8453 3.65202C16.1578 3.32545 16.4985 3.01452 16.8063 2.68014C15.8853 1.82307 14.8042 1.15617 13.625 0.717642C11.4777 -0.0620611 9.12811 -0.0830148 6.96721 0.658267Z"
                            fill="white"></path>
                          <path
                            d="M6.96563 0.657073C9.12635 -0.0847125 11.4759 -0.0643102 13.6234 0.714886C14.8028 1.15639 15.8834 1.82651 16.8031 2.68676C16.4906 3.02114 16.1609 3.33364 15.8422 3.65864C15.2359 4.26384 14.6302 4.86697 14.025 5.46801C13.4216 4.89104 12.6918 4.463 11.8937 4.21801C10.8725 3.90964 9.78597 3.88852 8.75347 4.15698C7.72097 4.42544 6.78236 4.97311 6.04062 5.73989C5.39318 6.39854 4.90285 7.19491 4.60625 8.06957L1.36719 5.56176C2.52658 3.26264 4.53398 1.50399 6.96563 0.657073Z"
                            fill="#E33629"></path>
                          <path
                            d="M0.510152 8.04688C0.684247 7.18405 0.973283 6.34848 1.36953 5.5625L4.60859 8.07656C4.18486 9.32438 4.18486 10.6772 4.60859 11.925C3.52942 12.7583 2.44974 13.5958 1.36953 14.4375C0.377575 12.463 0.0750466 10.2133 0.510152 8.04688Z"
                            fill="#F8BD00"></path>
                          <path
                            d="M10.1999 8.14844H19.4999C19.818 9.89365 19.732 11.6885 19.2484 13.3953C18.8034 14.9648 17.9391 16.3834 16.7484 17.4984C15.703 16.6828 14.653 15.8734 13.6077 15.0578C14.126 14.7082 14.5683 14.2576 14.9082 13.733C15.2481 13.2084 15.4786 12.6205 15.5859 12.0047H10.1999C10.1984 10.7203 10.1999 9.43437 10.1999 8.14844Z"
                            fill="#587DBD"></path>
                          <path
                            d="M1.36719 14.4383C2.4474 13.6049 3.52708 12.7674 4.60625 11.9258C5.02376 13.1511 5.81782 14.2131 6.875 14.9602C7.53439 15.4262 8.28364 15.7497 9.075 15.9102C9.85478 16.0551 10.6546 16.0551 11.4344 15.9102C12.2119 15.7785 12.9533 15.4858 13.6109 15.0508C14.6562 15.8664 15.7063 16.6758 16.7516 17.4914C15.6076 18.5316 14.2132 19.2568 12.7047 19.5961C11.0397 19.9875 9.30457 19.9687 7.64844 19.5414C6.3386 19.1917 5.11512 18.5751 4.05469 17.7305C2.93228 16.8394 2.01556 15.7164 1.36719 14.4383Z"
                            fill="#319F43"></path>
                        </g>
                        <defs>
                          <clipPath id="clip0_35_9997">
                            <rect width="20" height="20" fill="white"></rect>
                          </clipPath>
                        </defs>
                      </svg>
                      Sign in with Google
                    </button>
                    <button
                      class="btn btn-outline-primary bg-text/5 hover:bg-text/10 flex items-center gap-2 min-w-min w-full justify-center text-sm md:text-base"
                    >
                      <svg
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <g clip-path="url(#clip0_35_10005)">
                          <path d="M0 0H24V24H0V0Z" fill="#F3F3F3"></path>
                          <path
                            d="M1.04297 1.04349H11.4778V11.4783H1.04297V1.04349Z"
                            fill="#F35325"></path>
                          <path
                            d="M12.5234 1.04349H22.9582V11.4783H12.5234V1.04349Z"
                            fill="#81BC06"></path>
                          <path
                            d="M1.04297 12.5217H11.4778V22.9565H1.04297V12.5217Z"
                            fill="#05A6F0"></path>
                          <path
                            d="M12.5234 12.5217H22.9582V22.9565H12.5234V12.5217Z"
                            fill="#FFBA08"></path>
                        </g>
                        <defs>
                          <clipPath id="clip0_35_10005">
                            <rect width="24" height="24" fill="white"></rect>
                          </clipPath>
                        </defs>
                      </svg>

                      Sign in with Microsoft
                    </button>
                  </div>

                  <!-- divider -->
                  <div class="my-10 flex items-center gap-4">
                    <hr class="flex-1 border-border/5" />
                    <span class="text-sm text-text/80 whitespace-nowrap">
                      Or continue with
                    </span>
                    <hr class="flex-1 border-border/5" />
                  </div>
                  <form action="">
                    <div class="form-control">
                      <input
                        type="email"
                        name="email"
                        id="email"
                        placeholder="Email"
                        class="form-input"
                      />
                    </div>
                    <div class="form-control">
                      <input
                        type="password"
                        name="password"
                        id="password-input"
                        placeholder="Password"
                        class="form-input"
                      />
                    </div>
                    <div class="form-control">
                      <input
                        type="password"
                        name="confirmPassword"
                        id="confirm-password-input"
                        placeholder="Confirm Password"
                        class="form-input"
                      />
                    </div>

                    <button
                      id="submit-btn"
                      type="submit"
                      class="btn btn-primary px-6 py-3.5 text-base w-full leading-6 font-medium disabled:opacity-50 cursor-pointer"
                      disabled
                    >
                      Sign Up
                    </button>
                  </form>

                  <div class="mt-5 text-text">
                    Already have an account? <a
                      href="/login"
                      class="gradient-text-primary hover:underline">Sign in</a
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Bottom hero blob -->
            <div
              class="pointer-events-none absolute -bottom-92.75 left-1/2 z-0 h-129 w-[min(920px,100%)] -translate-x-1/2"
            >
              <div class="absolute inset-[-23.26%_-13.04%]">
                <svg
                  class="block size-full"
                  fill="none"
                  preserveAspectRatio="none"
                  viewBox="0 0 1160 756"
                >
                  <g filter="url(#filter-hero-blob)">
                    <path
                      d="M1040 636C1040 568.238 1028.1 501.139 1004.98 438.535C981.867 375.931 947.984 319.048 905.269 271.133C862.554 223.218 811.844 185.21 756.034 159.278C700.225 133.347 640.408 120 580 120C519.592 120 459.775 133.347 403.966 159.278C348.156 185.21 297.446 223.218 254.731 271.133C212.016 319.048 178.133 375.931 155.015 438.535C131.898 501.139 120 568.238 120 636L1040 636Z"
                      fill="url(#paint-hero-blob)"
                      fill-opacity="0.3"></path>
                  </g>
                  <defs>
                    <filter
                      color-interpolation-filters="sRGB"
                      filterUnits="userSpaceOnUse"
                      height="756"
                      id="filter-hero-blob"
                      width="1160"
                      x="0"
                      y="0"
                    >
                      <feFlood flood-opacity="0" result="BackgroundImageFix"
                      ></feFlood>
                      <feBlend
                        in="SourceGraphic"
                        in2="BackgroundImageFix"
                        mode="normal"
                        result="shape"></feBlend>
                      <feGaussianBlur
                        result="effect1_foregroundBlur"
                        stdDeviation="60"></feGaussianBlur>
                    </filter>
                    <linearGradient
                      gradientUnits="userSpaceOnUse"
                      id="paint-hero-blob"
                      x1="120"
                      x2="1040"
                      y1="636"
                      y2="636"
                    >
                      <stop stop-color="#8F2FFE"></stop>
                      <stop offset="1" stop-color="#DF53FE"></stop>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
            </div>
          </div>
        </section>
      </div>
      <div class="absolute -z-10 bottom-0 left-1/2 -translate-x-1/2">
        <CTAShape />
      </div>
    </MainContainer>
  </section>
</Base>
<script>
  function init() {
    const emailInput = document.getElementById("email") as HTMLInputElement;
    const passwordInput = document.getElementById(
      "password-input",
    ) as HTMLInputElement;
    const confirmPasswordInput = document.getElementById(
      "confirm-password-input",
    ) as HTMLInputElement;
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement;

    if (!emailInput || !passwordInput || !confirmPasswordInput || !submitBtn)
      return;

    function updateSubmitButtonState() {
      const emailFilled = emailInput.value.trim() !== "";
      const passwordFilled = passwordInput.value.trim() !== "";
      const confirmFilled = confirmPasswordInput.value.trim() !== "";
      const passwordsMatch = passwordInput.value === confirmPasswordInput.value;
      submitBtn.disabled = !(
        emailFilled &&
        passwordFilled &&
        confirmFilled &&
        passwordsMatch
      );
    }

    emailInput.addEventListener("input", updateSubmitButtonState);
    passwordInput.addEventListener("input", updateSubmitButtonState);
    confirmPasswordInput.addEventListener("input", updateSubmitButtonState);

    // Initial state
    updateSubmitButtonState();
  }

  // Runs on first load and after every View Transition navigation
  document.addEventListener("astro:page-load", init);
</script>
