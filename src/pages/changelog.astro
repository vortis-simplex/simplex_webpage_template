---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
import MainContainer from "@/components/MainContainer.astro";
import Badge from "@/components/Badge.astro";
import theme from "@/config/theme.json";
import { getListPage } from "@/lib/contentParser";

const data = await getListPage("changelog/-index.md");
const { title, description, meta_title, image, page_header, changelog_list } = data.frontmatter;
const callToAction = await getListPage("sections/call-to-action.md");
const primaryColor = theme?.colors?.default?.theme_color?.primary || "#8F2FFE";
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <PageHeader page_header={page_header} />

  {changelog_list && changelog_list.length > 0 && (
    <section>
      {changelog_list.map((item: any) => (
        <MainContainer>
          <div class="py-12 container-padding-x">
            <div class="flex flex-col gap-10">
              <div class="grid lg:grid-cols-[340px_1fr]">
                <div class="py-10 lg:px-12 flex flex-col items-end gap-5 border-b lg:border-b-0 lg:border-r border-border/6">
                  <Badge>v{item.version}</Badge>
                  <div class="text-text text-xl font-medium">{item.date}</div>
                </div>
                <div class="py-10 lg:px-12 flex flex-col gap-8">
                  <div class="flex flex-col gap-5">
                    <div class="flex flex-col gap-3">
                      <h2 class="text-h4 font-bold text-text">{item.title}</h2>
                      <div class="flex flex-wrap items-center gap-5">
                        <div class="bg-light px-4 py-1.5 rounded-full">
                          <span class="text-primary text-sm">Updates</span>
                        </div>
                        <div class="flex items-center gap-2">
                          <span class="text-text text-sm font-medium">{item.author}</span>
                        </div>
                        <div class="flex items-center gap-2">
                          <div class="w-1 h-1 rounded-full bg-text"></div>
                          <span class="text-text text-sm font-medium">{item.time}</span>
                        </div>
                      </div>
                    </div>
                    <p class="text-lg text-gray">{item.description}</p>
                  </div>
                  <div class="flex flex-col gap-6">
                    {item.categories.map((category: any) => (
                      <div class="flex flex-col gap-4">
                        <h3 class="text-lg font-bold text-text">{category.name}</h3>
                        <div class="flex flex-col gap-4">
                          {category.items.map((listItem: any) => (
                            <div class="flex items-start gap-3">
                              <div class="mt-2.5 shrink-0">
                                <div class="w-2 h-2 rounded-full" style={`background-color: ${primaryColor}`}></div>
                              </div>
                              <p class="text-base text-gray leading-relaxed">{listItem.text}</p>
                            </div>
                          ))}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </MainContainer>
      ))}
    </section>
  )}

  <CallToAction data={callToAction} />
</Base>
