---
// Pass the slug dynamically from Astro.params:
const { siteKey } = Astro.props;
---

<div data-open-remark data-site-key={siteKey}></div>

<script is:inline>
  function loadOpenRemark() {
    const oldScript = document.querySelector("script[data-open-remark-script]");
    if (oldScript) oldScript.remove();

    const script = document.createElement("script");
    script.src = "https://open-remark.zeon.studio/embed.js";
    script.async = true;
    script.setAttribute("data-open-remark-script", "true");
    document.body.appendChild(script);
  }

  loadOpenRemark();

  // re-mount on Astro page transitions
  document.addEventListener("astro:page-load", loadOpenRemark);
</script>
