---
interface Props {
  data: any;
}
const { data } = Astro.props;
const { title, image } = data.frontmatter;
const uid = `cscard-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class="bg-card/70 border border-border/6 rounded-3xl overflow-hidden w-full flex flex-col gap-0 group relative"
>
  <div class="absolute top-0 left-0 -z-1 size-full bg-radial-purple-dark opacity-0 group-hover:opacity-100 transition-all duration-300" />
  <div class="p-2.5 relative z-2">
    <a href={`/case-studies/${data.slug}`}>
      <div class="rounded-3xl overflow-hidden bg-dark/10 w-full aspect-1150/600 relative">
        {image ? (
          <img
            src={image}
            alt={title}
            width="1150"
            height="600"
            class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-gray">
            <span class="text-sm">No image available</span>
          </div>
        )}
      </div>
    </a>
  </div>
  <div class="px-5 pt-4 pb-5 flex-col gap-3">
    <a href={`/case-studies/${data.slug}`}>
      <h3 class="font-primary font-medium leading-tight text-h5 text-text hover:text-primary transition-colors duration-200 line-clamp-2">
        {title}
      </h3>
    </a>
    <a
      href={`/case-studies/${data.slug}`}
      class="btn btn-dark mt-10 w-fit group relative overflow-hidden"
    >
      <div class="size-full bg-gradient-primary absolute top-0 left-0 transition-all duration-500 opacity-0 group-hover:opacity-100" />
      <span class="relative z-2">Read Case Study</span>
    </a>
  </div>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initCaseStudyCards() {
    document.querySelectorAll<HTMLElement>('[id^="cscard-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initCaseStudyCards);
</script>
