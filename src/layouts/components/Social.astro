---
interface ISocial {
  name: string;
  icon: string;
  link: string;
}
interface Props {
  source: ISocial[];
  className: string;
}
const { source, className } = Astro.props;

const svgMap: Record<string, string> = {
  FaFacebook: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>',
  FaXTwitter: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  FaGithub: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>',
  FaLinkedin: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>',
  FaInstagram: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
  FaYoutube: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>',
};
---

<ul id={`social-${Math.random().toString(36).slice(2,8)}`} style="opacity:0" class={className}>
  {source.map((social) => (
    <li class="inline-block" style="opacity:0" data-social-item>
      <a
        aria-label={social.name}
        href={social.link}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="inline-block hover:scale-110 transition-transform duration-200"
      >
        <span class="sr-only">{social.name}</span>
        <Fragment set:html={svgMap[social.icon] ?? `<span>${social.name}</span>`} />
      </a>
    </li>
  ))}
</ul>

<script>
  import { animateMini as animate, inView } from "motion";
  function initSocialIcons() {
    document.querySelectorAll<HTMLElement>('[id^="social-"]').forEach((ul) => {
      ul.style.opacity = "0";
      ul.querySelectorAll<HTMLElement>("[data-social-item]").forEach((li) => {
        li.style.opacity = "0";
      });
      inView(ul, () => {
        animate(ul, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
        ul.querySelectorAll<HTMLElement>("[data-social-item]").forEach((li, i) => {
          animate(li, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.3, ease: "easeInOut", delay: i * 0.1 });
        });
      });
    });
  }
  document.addEventListener("astro:page-load", initSocialIcons);
</script>
