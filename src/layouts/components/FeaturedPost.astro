---
import dateFormat from "@/lib/utils/dateFormat";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { title, image, author, date } = data.frontmatter;
const uid = `featpost-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class="text-left relative bg-card/70 border border-border/6 rounded-3xl overflow-hidden w-full flex flex-col gap-0 mt-10"
>
  <!-- Purple Glow -->
  <div class="absolute -translate-x-1/2 left-1/2 w-86 h-86 -top-48.75 pointer-events-none">
    <div class="absolute inset-[-29.07%]">
      <svg class="block size-full" fill="none" preserveAspectRatio="none" viewBox="0 0 544 544">
        <g filter="url(#filter0_f_fp)">
          <circle cx="272" cy="272" fill="url(#paint0_fp)" fill-opacity="0.12" r="172"/>
        </g>
        <defs>
          <filter color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse" height="544" id="filter0_f_fp" width="544" x="0" y="0">
            <feFlood flood-opacity="0" result="BackgroundImageFix"/>
            <feBlend in="SourceGraphic" in2="BackgroundImageFix" mode="normal" result="shape"/>
            <feGaussianBlur result="effect1_foregroundBlur_fp" std-deviation="50"/>
          </filter>
          <linearGradient gradientUnits="userSpaceOnUse" id="paint0_fp" x1="100" x2="444" y1="444" y2="444">
            <stop stop-color="var(--color-primary)"/>
            <stop offset="1" stop-color="var(--color-secondary)"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
  </div>

  <!-- Hero Image -->
  <div class="p-5">
    <a href={`/blog/${data.slug}`}>
      <div class="rounded-3xl overflow-hidden bg-dark/10 w-full aspect-1150/600 relative">
        {image ? (
          <img src={image} alt={title} width="1150" height="600" class="object-cover w-full h-full" />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-gray">
            <span class="text-sm">No image available</span>
          </div>
        )}
      </div>
    </a>
  </div>

  <!-- Title -->
  <div class="px-6.5 sm:px-10 pt-6 pb-5">
    <a href={`/blog/${data.slug}`}>
      <h2 class="font-primary font-medium leading-[1.22] text-[22px] sm:text-[30px] lg:text-[36px] text-text hover:text-primary transition-colors duration-200">
        {title}
      </h2>
    </a>
  </div>

  <!-- Divider -->
  <div class="mx-6.5 sm:mx-10 h-px bg-border/6" />

  <!-- Author Row -->
  <div class="px-6.5 sm:px-10 py-5">
    <div class="flex items-center justify-between w-full">
      <div class="flex items-center gap-3">
        {author?.avatar && (
          <div class="shrink-0 size-10 sm:size-12 rounded-full overflow-hidden">
            <img src={author.avatar} alt={author.name} width="48" height="48" class="object-cover size-full" />
          </div>
        )}
        {author && (
          <div class="flex flex-col shrink-0">
            <p class="font-primary font-medium leading-[1.33] text-text text-[18px] sm:text-[24px]">{author.name}</p>
            {author.designation && (
              <p class="font-primary font-normal leading-normal text-gray text-[13px] sm:text-[16px]">{author.designation}</p>
            )}
          </div>
        )}
      </div>
      {date && (
        <p class="font-primary font-normal text-gray text-[13px] sm:text-[16px] opacity-[0.78] whitespace-nowrap">
          {dateFormat(date)}
        </p>
      )}
    </div>
  </div>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initFeaturedPosts() {
    document.querySelectorAll<HTMLElement>('[id^="featpost-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initFeaturedPosts);
</script>
