---
interface Props {
  data: any;
  featured?: boolean;
}
const { data, featured } = Astro.props;
const { title, job_info } = data.frontmatter;
const { employ_type, location, salary_range, department } = job_info;
const uid = `careercard-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class={`${featured ? "bg-card/20 border-border/10" : "bg-card/70"} border border-border/6 rounded-3xl p-10 flex lg:items-center lg:justify-between gap-8 group hover:bg-card/40 transition-all duration-300 flex-col lg:flex-row`}
>
  <div class="flex flex-col gap-1 min-w-0 flex-1">
    <a href={`/careers/${data.slug}`}>
      <h3 class="font-primary font-medium text-h6 text-text hover:text-primary transition-colors duration-200">
        {title}
      </h3>
    </a>
    <p class="text-gray">{department}</p>
  </div>
  <div class="flex items-center gap-3 flex-wrap">
    <span class="text-gray">{employ_type}</span>
    <div class="size-1 rounded-full bg-gray/40" />
    <span class="text-gray">{location}</span>
    <div class="size-1 rounded-full bg-gray/40" />
    <span class="text-gray">{salary_range}</span>
  </div>
  <a
    href={`/careers/${data.slug}`}
    class={`${featured ? "bg-gradient-primary" : "bg-gradient-dark"} btn btn-dark w-fit`}
  >
    Apply Now
  </a>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initCareerCards() {
    document.querySelectorAll<HTMLElement>('[id^="careercard-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initCareerCards);
</script>
