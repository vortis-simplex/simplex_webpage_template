---
import config from "@/config/config.json";
import ImageMod from "./ImageMod.astro";
interface Props {
  src?: string;
}
const { src } = Astro.props;
const { logo, logo_width, logo_height, logo_text, title } = config.site;
const w = parseInt(String(logo_width || 0), 10) || 0;
const h = parseInt(String(logo_height || 0), 10) || 0;
const logoPath = src ?? logo;
---

<a href="/" class="navbar-brand inline-block">
  {
    logoPath ? (
      <ImageMod
        src={logoPath}
        alt={title || "Site logo"}
        width={w * 2}
        height={h * 2}
        fetchpriority="high"
        loading="eager"
        style={`height:${h}px;width:${w}px`}
      />
    ) : logo_text ? (
      logo_text
    ) : (
      title
    )
  }
</a>
