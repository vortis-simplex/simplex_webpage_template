---
interface Props {
  plan: any;
}
const { plan } = Astro.props;
const uid = `pricingcard-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class="bg-card/70 border border-border/6 rounded-3xl p-2.5"
>
  <div class="bg-card border border-border/6 rounded-3xl p-7.5">
    <div class="size-14 bg-gradient-dark border border-border/6 rounded-2xl flex justify-center items-center relative overflow-hidden mb-3">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16.875 4.5H16.875C17.5712 4.5 18.2389 4.77656 18.7312 5.26884C19.2234 5.76113 19.5 6.4288 19.5 7.12499V7.125C19.5 7.82119 19.2234 8.48887 18.7312 8.98116C18.2389 9.47344 17.5712 9.75 16.875 9.75H14.25V7.125C14.25 6.42881 14.5266 5.76113 15.0188 5.26884C15.5111 4.77656 16.1788 4.5 16.875 4.5V4.5Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9.75 9.75H7.125C6.42881 9.75 5.76113 9.47344 5.26884 8.98116C4.77656 8.48887 4.5 7.82119 4.5 7.125V7.12499C4.5 6.4288 4.77656 5.76112 5.26884 5.26884C5.76112 4.77656 6.4288 4.5 7.12499 4.5H7.125C7.82119 4.5 8.48887 4.77656 8.98116 5.26884C9.47344 5.76113 9.75 6.42881 9.75 7.125V9.75Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14.25 14.25H16.875C17.5712 14.25 18.2389 14.5266 18.7312 15.0188C19.2234 15.5111 19.5 16.1788 19.5 16.875V16.875C19.5 17.5712 19.2234 18.2389 18.7312 18.7312C18.2389 19.2234 17.5712 19.5 16.875 19.5H16.875C16.1788 19.5 15.5111 19.2234 15.0188 18.7312C14.5266 18.2389 14.25 17.5712 14.25 16.875V14.25Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M7.125 19.5H7.12499C6.4288 19.5 5.76112 19.2234 5.26884 18.7312C4.77656 18.2389 4.5 17.5712 4.5 16.875V16.875C4.5 16.1788 4.77656 15.5111 5.26884 15.0188C5.76113 14.5266 6.42881 14.25 7.125 14.25H9.75V16.875C9.75 17.5712 9.47344 18.2389 8.98116 18.7312C8.48887 19.2234 7.82119 19.5 7.125 19.5V19.5Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9.75 9.75H14.25V14.25H9.75V9.75Z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h3 class="text-h5 font-medium mb-2">{plan.name}</h3>
    <p class="text-gray mb-6">{plan.description}</p>
    <div class="mb-6">
      <span class="text-[48px] font-light">{plan.price?.monthly ?? plan.price}</span>
      {plan.price?.monthly !== undefined && <span class="text-gray">/mo</span>}
    </div>
    {plan.button?.enable && (
      <a href={plan.button.link} class="btn btn-primary w-full text-center mb-8">{plan.button.label}</a>
    )}
    {plan.services && (
      <ul class="flex flex-col gap-3">
        {plan.services.map((service: any) => (
          <li class="flex items-center gap-3 text-gray">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M2.667 8l3.333 3.333L13.333 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {service}
          </li>
        ))}
      </ul>
    )}
  </div>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initPricingCards() {
    document.querySelectorAll<HTMLElement>('[id^="pricingcard-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initPricingCards);
</script>
