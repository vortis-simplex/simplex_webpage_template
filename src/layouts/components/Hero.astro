---
import AnimatedButton from "@/components/AnimatedButton.astro";
import HeroShape from "@/components/shape/HeroShape";
import { markdownify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";
interface Props {
  data: any;
}
const { data } = Astro.props;
---

<section class="overflow-hidden relative">
  <div class="h-full w-px bg-light/8 absolute top-0 left-1/2 -translate-x-1/2">
  </div>
  <div class="main-container">
    <div class="container px-0">
      <div class="container-padding-y pb-0 px-0">
        <div class="flex justify-center items-center flex-col text-center px-4">
          <!-- BADGE -->
          {
            data.badge?.enable && (
              <div
                id="hero-badge"
                class="bg-gradient-secondary p-px rounded-full mb-2"
              >
                <div class="px-1.5 py-1.75 bg-gradient-black-grid rounded-full flex items-center gap-2.5">
                  <ul class="flex">
                    {data.badge.images.map((src: string) => (
                      <li class="border border-secondary rounded-full -mr-2 last:mr-0 size-6">
                        <ImageMod
                          src={src}
                          alt="avatar"
                          width={24}
                          height={24}
                          class="rounded-full object-cover size-full"
                        />
                      </li>
                    ))}
                  </ul>
                  <p class="gradient-text-primary pr-3">{data.badge.label}</p>
                </div>
              </div>
            )
          }
          <!-- TITLE -->
          <h1
            id="hero-title"
            class="hero-text mb-4"
            set:html={markdownify(data.title).__html}
          />
          <!-- CONTENT -->
          <p id="hero-content" class="text-lg sm:w-3/5">
            {data.content}
          </p>
          <!-- BUTTONS -->
          <div
            id="hero-buttons"
            class="mt-10 flex items-center gap-5 flex-wrap justify-center"
          >
            {
              data.button_dark?.enable && (
                <AnimatedButton
                  classNames="btn btn-dark"
                  href={data.button_dark?.link || "/"}
                >
                  {data.button_dark?.label}
                </AnimatedButton>
              )
            }
            {
              data.button_primary?.enable && (
                <AnimatedButton
                  classNames="btn btn-primary"
                  href={data.button_primary?.link || "/"}
                >
                  {data.button_primary?.label}
                </AnimatedButton>
              )
            }
          </div>
        </div>

        <!-- IMAGE -->
        <div
          id="hero-image"
          class="mt-30 bg-dark/45 backdrop-blur-2xl p-5 relative z-1"
        >
          <ImageMod
            src={data.image}
            alt="banner"
            width={1360}
            height={800}
            fetchpriority="high"
            loading="eager"
            class="object-cover w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Shape -->
  <div
    id="hero-shape"
    class="absolute bottom-20 -z-1 left-1/2 -translate-x-1/2 pointer-events-none h-100 sm:h-150 lg:h-170 xl:h-210"
  >
    <HeroShape />
  </div>
</section>

<script>
  import { animateMini as animate } from "motion";
  function initHero() {
    const smooth = { ease: "easeInOut" as const };
    const badge = document.getElementById("hero-badge");
    const title = document.getElementById("hero-title");
    const content = document.getElementById("hero-content");
    const buttons = document.getElementById("hero-buttons");
    const heroImage = document.getElementById("hero-image");
    const heroShape = document.getElementById("hero-shape");
    if (badge) {
      badge.style.opacity = "0";
      animate(
        badge,
        { opacity: [0, 1], transform: ["translateY(-20px)", "translateY(0)"] },
        { ...smooth, duration: 0.5, delay: 0.2 },
      );
    }
    if (title) {
      title.style.opacity = "0";
      animate(
        title,
        { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] },
        { ...smooth, duration: 0.8, delay: 0.3 },
      );
    }
    if (content) {
      content.style.opacity = "0";
      animate(
        content,
        { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] },
        { ...smooth, duration: 0.5, delay: 0.5 },
      );
    }
    if (buttons) {
      buttons.style.opacity = "0";
      animate(
        buttons,
        { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] },
        { ...smooth, duration: 0.5, delay: 0.6 },
      );
    }
    if (heroImage) {
      heroImage.style.opacity = "0";
      animate(
        heroImage,
        { opacity: [0, 1], transform: ["translateY(40px)", "translateY(0)"] },
        { ...smooth, duration: 1.2, delay: 0.4 },
      );
    }
    if (heroShape) {
      heroShape.style.opacity = "0";
      animate(
        heroShape,
        { opacity: [0, 1], transform: ["scale(0.8)", "scale(1)"] },
        { ...smooth, duration: 1.2, delay: 0.2 },
      );
    }
  }
  document.addEventListener("astro:page-load", initHero);
</script>
