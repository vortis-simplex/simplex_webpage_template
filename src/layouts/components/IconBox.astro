---
// IconBox — converted from IconBox.tsx (motion-only, no React state)
interface Props {
  icon: string;
}
const { icon } = Astro.props;
const uid = `iconbox-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class="border border-border/6 bg-gradient-dark size-22.5 rounded-4xl flex items-center justify-center mb-7"
>
  <img src={icon} alt="Icon" width="44" height="44" />
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initIconBoxes() {
    document.querySelectorAll<HTMLElement>('[id^="iconbox-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["scale(0.8)", "scale(1)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initIconBoxes);
</script>
