---
import Badge from "@/components/Badge.astro";
interface Props {
  title: string;
  badge: string;
}
const { title, badge } = Astro.props;
const uid = `sh-${Math.random().toString(36).slice(2, 8)}`;
---

<div id={uid} style="opacity:0" class="text-center mb-14">
  {badge && <Badge>{badge}</Badge>}
  <h2 class="text-h2 font-medium lg:w-2/5 mx-auto">{title}</h2>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initSectionHeaders() {
    document.querySelectorAll<HTMLElement>('[id^="sh-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      });
    });
  }
  document.addEventListener("astro:page-load", initSectionHeaders);
</script>
