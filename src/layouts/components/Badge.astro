---
// Badge — converted from Badge.tsx (motion-only, no React state)
---

<div
  id={`badge-${Math.random().toString(36).slice(2, 8)}`}
  style="opacity:0"
  class="bg-gradient-primary p-px inline-block rounded-full mb-2"
>
  <div class="bg-gradient-black-grid px-4 py-1.5 rounded-full">
    <span class="gradient-text-primary"><slot /></span>
  </div>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initBadgeAnimations() {
    document.querySelectorAll<HTMLElement>('[id^="badge-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["scale(0.8)", "scale(1)"] }, { duration: 0.5, ease: "easeInOut" });
      });
    });
  }
  document.addEventListener("astro:page-load", initBadgeAnimations);
</script>
