---
interface Props {
  section: string;
  currentPage: number;
  totalPages: number;
}
const { section, currentPage, totalPages } = Astro.props;
const indexPageLink = currentPage === 2;
const hasPrevPage = currentPage > 1;
const hasNextPage = totalPages > currentPage;
const pageList = Array.from({ length: totalPages }, (_, i) => i + 1);

const prevHref = indexPageLink
  ? `${section ? "/" + section : "/"}`
  : `${section ? "/" + section : ""}/page/${currentPage - 1}`;
const nextHref = `${section ? "/" + section : ""}/page/${currentPage + 1}`;
---

{totalPages > 1 && (
  <nav
    class="flex items-center justify-center space-x-2 border border-border/6 rounded-full w-max mx-auto overflow-hidden"
    aria-label="Pagination"
  >
    <!-- previous -->
    {hasPrevPage ? (
      <a
        href={prevHref}
        class="size-10 flex items-center justify-center text-text hover:bg-light duration-300 hover:text-text-dark border-r border-border/6"
      >
        <span class="sr-only">Previous</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_35_10935)">
            <path d="M16.875 10H3.125M3.125 10L8.75 4.375M3.125 10L8.75 15.625" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs><clipPath id="clip0_35_10935"><rect width="20" height="20" fill="currentColor"/></clipPath></defs>
        </svg>
      </a>
    ) : (
      <span class="size-10 flex items-center justify-center text-gray border-r border-border/6">
        <span class="sr-only">Previous</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_35_10935b)">
            <path d="M16.875 10H3.125M3.125 10L8.75 4.375M3.125 10L8.75 15.625" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs><clipPath id="clip0_35_10935b"><rect width="20" height="20" fill="currentColor"/></clipPath></defs>
        </svg>
      </span>
    )}

    <!-- page index -->
    {pageList.map((pagination, i) => (
      pagination === currentPage ? (
        <span
          aria-current="page"
          class="rounded-full bg-gradient-primary size-10 flex items-center justify-center text-text-light"
        >
          {pagination}
        </span>
      ) : (
        <a
          href={i === 0 ? `${section ? "/" + section : "/"}` : `${section ? "/" + section : ""}/page/${pagination}`}
          aria-current="page"
          class="rounded-full size-10 flex items-center justify-center text-text hover:bg-light duration-300 hover:text-text-dark"
        >
          {pagination}
        </a>
      )
    ))}

    <!-- next page -->
    {hasNextPage ? (
      <a
        href={nextHref}
        class="size-10 flex items-center justify-center text-text hover:bg-light duration-300 hover:text-text-dark border-l border-border/6"
      >
        <span class="sr-only">Next</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_35_10946)">
            <path d="M3.125 10H16.875M16.875 10L11.25 4.375M16.875 10L11.25 15.625" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs><clipPath id="clip0_35_10946"><rect width="20" height="20" fill="currentColor"/></clipPath></defs>
        </svg>
      </a>
    ) : (
      <span class="size-10 flex items-center justify-center text-gray border-l border-border/6">
        <span class="sr-only">Next</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g clip-path="url(#clip0_35_10946b)">
            <path d="M3.125 10H16.875M16.875 10L11.25 4.375M16.875 10L11.25 15.625" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </g>
          <defs><clipPath id="clip0_35_10946b"><rect width="20" height="20" fill="currentColor"/></clipPath></defs>
        </svg>
      </span>
    )}
  </nav>
)}
