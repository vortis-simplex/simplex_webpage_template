---
import dateFormat from "@/lib/utils/dateFormat";
import { plainify } from "@/lib/utils/textConverter";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { title, image, author, date } = data.frontmatter;
const uid = `blogcard-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  style="opacity:0"
  class="bg-card/70 border border-border/6 rounded-3xl overflow-hidden w-full flex flex-col gap-0 group relative"
>
  <div class="absolute inset-0 size-full bg-radial-purple-dark transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
  <!-- Image -->
  <div class="p-2.5">
    <a href={`/blog/${data.slug}`}>
      <div class="rounded-3xl overflow-hidden bg-dark/10 w-full aspect-1150/600 relative">
        {image ? (
          <img
            src={image}
            alt={title}
            width="1150"
            height="600"
            class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-gray">
            <span class="text-sm">No image available</span>
          </div>
        )}
      </div>
    </a>
  </div>
  <!-- Content -->
  <div class="px-5 pt-4 pb-5 flex flex-col gap-3 relative z-2">
    <a href={`/blog/${data.slug}`}>
      <h3 class="font-primary font-medium leading-tight text-h5 text-text hover:text-primary transition-colors duration-200 line-clamp-2">
        {title}
      </h3>
    </a>
    <p class="line-clamp-2 text-gray">{plainify(data.content || "")}</p>
    <div class="flex items-center justify-between w-full mt-16">
      <div class="flex items-center gap-2.5">
        {author?.avatar && (
          <div class="shrink-0 size-8 rounded-full overflow-hidden border border-border/6">
            <img src={author.avatar} alt={author.name} width="32" height="32" class="object-cover size-full" />
          </div>
        )}
        {author && (
          <div class="flex flex-col">
            <p class="font-primary font-medium text-sm text-text leading-tight">{author.name}</p>
            {author.designation && (
              <p class="font-primary font-normal text-xs text-gray leading-tight">{author.designation}</p>
            )}
          </div>
        )}
      </div>
      {date && (
        <p class="font-primary font-normal text-xs text-gray opacity-[0.78] whitespace-nowrap">
          {dateFormat(date)}
        </p>
      )}
    </div>
  </div>
</div>

<script>
  import { animateMini as animate, inView } from "motion";
  function initBlogCards() {
    document.querySelectorAll<HTMLElement>('[id^="blogcard-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initBlogCards);
</script>
