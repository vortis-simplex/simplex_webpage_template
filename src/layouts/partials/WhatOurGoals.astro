---
import SectionHeader from "@/components/SectionHeader.astro";
import { markdownify } from "@/lib/utils/textConverter";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { badge, title, image, mission, vision } = data;
---

<section class="overflow-hidden">
  <div class="main-container">
    <div class="container">
      <div class="container-padding-y container-padding-x">
        <SectionHeader title={title} badge={badge} />
        <div class="grid lg:grid-cols-2 gap-2.5 items-center">
          <!-- Left: image -->
          <div id={`wog-left-${Math.random().toString(36).slice(2,8)}`} style="opacity:0" class="border border-border/6 bg-card rounded-3xl p-2.5 h-full">
            <img src={image} width="800" height="600" class="w-full rounded-3xl object-cover h-full" alt="goals" />
          </div>
          <!-- Right: mission + vision -->
          <div id={`wog-right-${Math.random().toString(36).slice(2,8)}`} style="opacity:0" class="grid gap-5">
            <!-- Mission -->
            <div class="border border-border/6 bg-card/70 rounded-3xl p-10 hover:border-primary/20 transition-colors duration-300">
              <div class="border border-border/6 bg-gradient-dark size-14 rounded-xl flex items-center justify-center mb-6">
                <img src={mission.icon} alt="mission icon" width="24" height="24" />
              </div>
              <h3 class="mb-4 text-2xl font-medium">{mission.title}</h3>
              <p class="text-gray/70" set:html={markdownify(mission.content).__html} />
            </div>
            <!-- Vision -->
            <div class="border border-border/6 bg-card/70 rounded-3xl p-10 hover:border-primary/20 transition-colors duration-300">
              <div class="border border-border/6 bg-gradient-dark size-14 rounded-xl flex items-center justify-center mb-6">
                <img src={vision.icon} alt="vision icon" width="24" height="24" />
              </div>
              <h3 class="mb-4 text-2xl font-medium">{vision.title}</h3>
              <p class="text-gray/70" set:html={markdownify(vision.content).__html} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animateMini as animate, inView } from "motion";
  function initWhatOurGoals() {
    document.querySelectorAll<HTMLElement>('[id^="wog-left-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateX(-30px)", "translateX(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
    document.querySelectorAll<HTMLElement>('[id^="wog-right-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateX(30px)", "translateX(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initWhatOurGoals);
</script>
