---
import AnimatedButton from "@/components/AnimatedButton.astro";
import Badge from "@/components/Badge.astro";
import CTAShape from "@/components/shape/CTAShape";
import { markdownify } from "@/lib/utils/textConverter";
interface Props {
  page_header: {
    title: string;
    badge?: string;
    subtitle?: string;
    button_primary?: any;
    button_dark?: any;
  };
}
const { page_header } = Astro.props;
const { title, badge, subtitle, button_primary, button_dark } = page_header;
const uid = `ph-${Math.random().toString(36).slice(2, 8)}`;
---

<section id={uid} style="opacity:0" class="relative overflow-hidden mb-10">
  <div class="main-container">
    <div class="container">
      <div class="container-padding-x container-padding-y relative z-1">
        <div class="text-center">
          {badge && <Badge>{badge}</Badge>}
          <h1 set:html={markdownify(title).__html} class="hero-text" />
          {subtitle && <p class="mt-4 text-lg sm:w-2/4 mx-auto text-gray">{subtitle}</p>}
          {(button_dark || button_primary) && (
            <div class="mt-10 flex items-center gap-5 flex-wrap justify-center">
              {button_dark?.enable && (
                <AnimatedButton classNames="btn bg-dark/30 border border-border/6" href={button_dark?.link || "/"}>
                  {button_dark?.label}
                </AnimatedButton>
              )}
              {button_primary?.enable && (
                <AnimatedButton classNames="btn btn-primary" href={button_primary?.link || "/"}>
                  {button_primary?.label}
                </AnimatedButton>
              )}
            </div>
          )}
          <div class="mt-10">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 -z-10">
    <CTAShape />
  </div>
</section>

<script>
  import { animateMini as animate, inView } from "motion";
  function initPageHeaders() {
    document.querySelectorAll<HTMLElement>('[id^="ph-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initPageHeaders);
</script>
