---
import Logo from "@/components/Logo.astro";
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
const { copyright } = config.params;
const { footer_company, footer_legal, footer_resource } = menu;
---

<footer class="pt-25">
  <div class="container">
    <div id="footer-main" style="opacity:0" class="grid md:grid-cols-6 gap-y-12 relative z-1">
      <div class="md:col-span-3">
        <Logo />
        <p class="text-gray mb-10 mt-3 md:w-2/5">{config.params.footer_text}</p>
        <ul>
          <li class="mb-2">
            <a href={`mailto:${config.params.mail}`} class="text-text hover:text-primary transition text-lg">
              {config.params.mail}
            </a>
          </li>
          <li class="mb-2">
            <a href={`tel:${config.params.phone}`} class="text-text hover:text-primary transition text-lg">
              {config.params.phone}
            </a>
          </li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <div class="grid sm:grid-cols-3 gap-y-10 sm:gap-y-6">
          <div>
            <h3 class="text-xl font-medium mb-10">Company</h3>
            <ul class="flex flex-col gap-y-3">
              {footer_company.map((item: any) => (
                <li><a href={item.url} class="text-gray hover:text-primary transition">{item.name}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-medium mb-10">Resources</h3>
            <ul class="flex flex-col gap-y-3">
              {footer_resource.map((item: any) => (
                <li><a href={item.url} class="text-gray hover:text-primary transition">{item.name}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-medium mb-10">Legal</h3>
            <ul class="flex flex-col gap-y-3">
              {footer_legal.map((item: any) => (
                <li><a href={item.url} class="text-gray hover:text-primary transition">{item.name}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom footer -->
    <div id="footer-bottom" style="opacity:0" class="lg:sticky bottom-0 z-0 relative">
      <h1 class="footer-title leading-tight mt-12 lg:mt-20">{config.site.title}</h1>
      <div class="flex justify-between lg:-translate-y-12 items-center flex-col sm:flex-row gap-y-6 py-6">
        <p class="text-text text-sm" set:html={markdownify(copyright).__html} />
        <Social source={social.main} className="social-icons" />
      </div>
    </div>
  </div>
</footer>

<script>
  import { animateMini as animate, inView } from "motion";
  function initFooter() {
    const smooth = { duration: 0.5, ease: "easeInOut" as const };
    const footerMain = document.getElementById("footer-main");
    if (footerMain) {
      footerMain.style.opacity = "0";
      inView(footerMain, () => {
        animate(footerMain, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, smooth);
      }, { margin: "0px", amount: 0.05 });
    }
    const footerBottom = document.getElementById("footer-bottom");
    if (footerBottom) {
      footerBottom.style.opacity = "0";
      inView(footerBottom, () => {
        animate(footerBottom, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, smooth);
      }, { margin: "0px", amount: 0.05 });
    }
  }
  document.addEventListener("astro:page-load", initFooter);
</script>
