---
import Badge from "@/components/Badge.astro";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { enable, badge, title, images } = data;
---

{enable && (
  <section>
    <div class="main-container">
      <div class="container">
        <div class="container-padding-y container-padding-x">
          <div id={`gallery-header-${Math.random().toString(36).slice(2,8)}`} style="opacity:0" class="text-center mb-14">
            {badge && <Badge>{badge}</Badge>}
            <h2 class="text-h1 font-medium lg:w-4/5 mx-auto" set:html={title} />
          </div>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-2.5 grid-rows-5">
            {images.map((image: string, index: number) => {
              const uid = `gallery-img-${Math.random().toString(36).slice(2, 8)}`;
              return (
                <div
                  id={uid}
                  style="opacity:0"
                  class={`${index % 2 === 0 ? "md:row-span-2" : "md:row-span-3"} ${index === 4 ? "lg:row-span-3!" : ""}`}
                >
                  <img
                    src={image}
                    alt={`Gallery image ${index + 1}`}
                    width="400"
                    height="400"
                    class="w-full h-full object-cover rounded-xl"
                  />
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<script>
  import { animateMini as animate, inView } from "motion";
  function initGallery() {
    document.querySelectorAll<HTMLElement>('[id^="gallery-header-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
    document.querySelectorAll<HTMLElement>('[id^="gallery-img-"]').forEach((el, i) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut", delay: i * 0.08 });
      }, { margin: "-100px", amount: 0.1 });
    });
  }
  document.addEventListener("astro:page-load", initGallery);
</script>
