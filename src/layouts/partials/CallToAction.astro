---
import AnimatedButton from "@/components/AnimatedButton.astro";
import CTAShape from "@/components/shape/CTAShape";
interface Props {
  data: any;
}
const { data } = Astro.props;
const uid = `cta-${Math.random().toString(36).slice(2, 8)}`;
---

{data.frontmatter.enable && (
  <section class="relative overflow-hidden">
    <div class="main-container">
      <div class="container">
        <div id={uid} style="opacity:0" class="container-padding-y text-center">
          <h1 class="mb-5 hero-text sm:w-4/6 mx-auto">{data.frontmatter.title}</h1>
          <p class="text-lg mb-10 sm:w-3/6 mx-auto">{data.frontmatter.description}</p>
          <div class="mt-10 flex justify-center gap-4">
            {data.frontmatter.button?.enable && (
              <AnimatedButton href={data.frontmatter.button.link} classNames="btn btn-primary">
                {data.frontmatter.button.label}
              </AnimatedButton>
            )}
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 -z-10">
      <CTAShape />
    </div>
  </section>
)}

<script>
  import { animateMini as animate, inView } from "motion";
  function initCTAs() {
    document.querySelectorAll<HTMLElement>('[id^="cta-"]').forEach((el) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut" });
      }, { margin: "0px", amount: 0.05 });
    });
  }
  document.addEventListener("astro:page-load", initCTAs);
</script>
