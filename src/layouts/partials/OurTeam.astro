---
import SectionHeader from "@/components/SectionHeader.astro";
interface Props {
  data: any;
}
const { data } = Astro.props;
const { badge, title, team_list } = data;
---

<section>
  <div class="main-container">
    <div class="container">
      <div class="container-padding-y container-padding-x">
        <SectionHeader title={title} badge={badge} />
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-2.5">
          {team_list.map((member: any) => {
            const uid = `team-${Math.random().toString(36).slice(2, 8)}`;
            return (
              <div
                id={uid}
                style="opacity:0"
                class="bg-card/70 flex flex-col gap-5 items-start pb-5 pt-2.5 px-2.5 relative rounded-3xl w-full border border-border/6 group"
              >
                <img
                  src={member.image}
                  alt={member.name}
                  width="300"
                  height="300"
                  class="w-full h-full object-cover rounded-3xl object-top grayscale-100 group-hover:grayscale-0 transition-all duration-300"
                />
                <div class="relative shrink-0 w-full">
                  <div class="flex flex-col gap-1 items-start px-4">
                    <h3 class="font-medium text-2xl">{member.name}</h3>
                    <p class="text-gray">{member.position}</p>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animateMini as animate, inView } from "motion";
  function initOurTeam() {
    document.querySelectorAll<HTMLElement>('[id^="team-"]').forEach((el, i) => {
      el.style.opacity = "0";
      inView(el, () => {
        animate(el, { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] }, { duration: 0.5, ease: "easeInOut", delay: i * 0.1 });
      }, { margin: "-100px", amount: 0.1 });
    });
  }
  document.addEventListener("astro:page-load", initOurTeam);
</script>
