---
import BlogCard from "@/components/BlogCard.astro";
import MainContainer from "@/components/MainContainer.astro";
import Share from "@/components/Share.astro";
import config from "@/config/config.json";
import { getSinglePage } from "@/lib/contentParser";
import dateFormat from "@/lib/utils/dateFormat";
import readingTime from "@/lib/utils/readingTime";
import { slug } from "github-slugger";
import { render } from "astro:content";
import OpenRemarkComment from "./components/OpenRemarkComment.astro";

const { post } = Astro.props;

if (post.data.draft) return Astro.redirect("/404");

const { Content, headings } = await render(post);
const { title, description, image, author, category, date } = post.data;

const allPosts = await getSinglePage("blog");
const relatedPosts = allPosts
  .filter((p: any) => p.slug !== post.id && p.frontmatter.category === category)
  .slice(0, 3);

const readTime = post.body ? readingTime(post.body) : "0 min";

const toc: { level: number; text: string; slug: string }[] = [];
if (headings) {
  for (let i = 0; i < headings.length; i++) {
    const { depth: level, text } = headings[i];
    const headingSlug = slug(text) || `section-${i + 1}`;
    toc.push({ level, text, slug: headingSlug });
  }
}
---

<section>
  <MainContainer>
    <div class="container-padding-x container-padding-y pb-14">
      <div class="flex flex-col items-center gap-10">
        <h1
          class="font-primary font-semibold leading-[1.2] md:text-[60px] text-center text-text"
        >
          {title}
        </h1>
        <p class="text-lg text-gray sm:w-2/3 text-center">{description}</p>
        <div class="flex items-center gap-4 flex-wrap justify-center">
          <div
            class="flex flex-col justify-center gap-5 p-5 w-70 bg-card/70 border border-border/6 rounded-2xl"
          >
            <p class="font-primary font-normal text-base text-gray">Author</p>
            <p class="font-primary font-medium text-xl text-text">
              {author?.name || "Unknown"}
            </p>
          </div>
          <div
            class="flex flex-col justify-center gap-5 p-5 w-70 bg-card/70 border border-border/6 rounded-2xl"
          >
            <p class="font-primary font-normal text-[16px] text-gray">
              Category
            </p>
            <p class="font-primary font-medium text-xl text-text">
              {category || "Uncategorized"}
            </p>
          </div>
          <div
            class="flex flex-col justify-center gap-5 p-5 w-70 bg-card/70 border border-border/6 rounded-2xl"
          >
            <p class="font-primary font-normal text-[16px] text-gray">
              Read Time
            </p>
            <p class="font-primary font-medium text-xl text-text">{readTime}</p>
          </div>
          <div
            class="flex flex-col justify-center gap-5 p-5 w-70 bg-card/70 border border-border/6 rounded-2xl"
          >
            <p class="font-primary font-normal text-[16px] text-gray">
              Published Date
            </p>
            <p class="font-primary font-medium text-xl text-text">
              {date ? dateFormat(date) : "Unknown"}
            </p>
          </div>
        </div>
        {
          image && (
            <img
              src={image}
              alt={title}
              width="640"
              height="640"
              class="w-full h-auto sm:h-100 object-cover rounded-2xl"
            />
          )
        }
      </div>
    </div>
  </MainContainer>
</section>

<section>
  <MainContainer>
    <div class="container-padding-x py-12">
      <div class="grid lg:grid-cols-6 gap-y-12">
        <div class="lg:col-span-2 order-2 lg:order-0">
          <div class="flex flex-col gap-2.5 lg:pr-12 sticky top-32">
            <div class="border border-border/6 bg-card/70 p-8 rounded-2xl">
              <h3 class="font-primary font-medium text-xl text-text mb-8">
                Inside the page
              </h3>
              {
                toc.length > 0 ? (
                  <ul class="flex flex-col gap-1">
                    {toc.map((item) => {
                      const indentClass =
                        item.level < 2
                          ? "pl-0"
                          : item.level === 2
                            ? "pl-3"
                            : item.level === 3
                              ? "pl-6"
                              : "pl-9";
                      return (
                        <li class={indentClass}>
                          <a
                            href={`#${item.slug}`}
                            class="font-primary text-[15px] leading-6 text-gray hover:text-text transition-colors duration-200 wrap-break-word"
                          >
                            {item.text}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                ) : (
                  <p class="font-primary text-[15px] leading-6 text-gray">
                    No headings available in this post.
                  </p>
                )
              }
            </div>
            <div class="border border-border/6 bg-card/70 p-8 rounded-2xl">
              <h3 class="font-primary font-medium text-xl text-text mb-8">
                Share this
              </h3>
              <Share
                title={title}
                description={description}
                slug={`blog/${post.id}`}
                className="social-icons flex gap-4 flex-wrap"
              />
            </div>
            <div class="border border-border/6 bg-card/70 p-8 rounded-2xl">
              <h3 class="font-primary font-medium text-xl text-text mb-8">
                Subscribe for newsletter
              </h3>
              <form
                class="flex flex-col gap-4"
                method="POST"
                action={config.params.newsletter_form_action}
              >
                <div class="relative">
                  <input
                    type="email"
                    placeholder="Email"
                    required
                    class="w-full px-7.5 py-3 bg-transparent border border-border/6 rounded-[120px] font-primary font-normal text-[16px] text-text placeholder:text-gray focus:outline-none focus:border-primary/50 transition-colors duration-200"
                  />
                </div>
                <button class="w-full px-7.5 py-3.5 btn btn-primary"
                  >Subscribe</button
                >
              </form>
            </div>
          </div>
        </div>
        <div class="lg:col-span-4 order-1 lg:order-0">
          <div class="lg:border-l lg:border-border/6 lg:pl-12">
            <div class="content">
              <Content />
            </div>
            {
              config["open-remark-comment"].enable && (
                <div class="mt-10">
                  <OpenRemarkComment
                    siteKey={config["open-remark-comment"].siteKey}
                  />
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </MainContainer>
</section>

{
  relatedPosts.length > 0 && (
    <section>
      <MainContainer>
        <div class="container-padding-x py-14">
          <h2 class="font-primary font-semibold text-3xl text-text text-center mb-10">
            Related Blogs
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-2.5">
            {relatedPosts.map((relatedPost: any) => (
              <BlogCard data={relatedPost} />
            ))}
          </div>
        </div>
      </MainContainer>
    </section>
  )
}
